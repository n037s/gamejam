<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="ScorePanel" style="position: absolute; top: 20%; left: auto; background-color: rgba(0, 0, 0, 0.45); border-radius: 6px; padding: 8px 10px; min-width: 160px; align-items: flex-start; right: 5px;">
        <ui:Label name="MyScoreLabel" text="Score: 0" style="-unity-font-style: bold; color: rgb(255, 255, 255); font-size: 12px; margin-bottom: 6px;"/>
        <ui:Label name="ScoreboardLabel" text="" style="color: rgb(220, 220, 220); font-size: 10px; white-space: normal;"/>
    </ui:VisualElement>
</ui:UXML>
